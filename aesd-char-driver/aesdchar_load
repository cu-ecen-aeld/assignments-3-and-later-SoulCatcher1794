#!/bin/sh
module=aesdchar
device=aesdchar
mode="664"
cd `dirname $0`
set -e

# Prefer the primary group of the user invoking sudo so non-root tests can open
# /dev/aesdchar with O_RDWR. Fallback to the current user's primary group.
owner_user="${SUDO_USER:-$USER}"
group=$(id -gn "$owner_user" 2>/dev/null || id -gn)

if [ -e ${module}.ko ]; then
    echo "Loading local built file ${module}.ko"
    insmod ./$module.ko $* || exit 1
else
    echo "Local file ${module}.ko not found, attempting to modprobe"
    modprobe ${module} || exit 1
fi
major=$(awk "\$2==\"$module\" {print \$1}" /proc/devices)
rm -f /dev/${device}
mknod /dev/${device} c $major 0
chgrp $group /dev/${device}
chmod $mode  /dev/${device}
